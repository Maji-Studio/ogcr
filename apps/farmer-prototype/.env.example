# Database (Local Development with Docker)
# For local development, use: postgresql://postgres:postgres@localhost:5432/app_template_dev
# For production, use your hosted PostgreSQL URL (Vercel Postgres, Supabase, etc.)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app_template_dev

# Docker PostgreSQL Configuration (optional overrides)
# Uncomment and modify these if you need to change defaults
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=app_template_dev
# POSTGRES_PORT=5432

# App URL (used by Better Auth and other services)
NEXT_PUBLIC_APP_URL=http://localhost:3100

# Better Auth
BETTER_AUTH_SECRET=your-32-character-secret-here-change-this

# Email (Resend)
# Optional for local development (auth links will be logged to server console)
# Required for production email delivery
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Admin Configuration
ADMIN_EMAIL=admin@example.com
ALLOW_SELF_SIGNUP=false

# Optional
LOG_LEVEL=info

# Database Pool (optional production tuning)
# DB_POOL_MAX=20
# DB_POOL_IDLE_TIMEOUT_MS=30000
# DB_POOL_CONNECTION_TIMEOUT_MS=10000
