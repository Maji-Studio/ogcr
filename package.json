{
  "name": "ogcr-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "OGCR monorepo — the OGCR design system and the apps that consume it.",
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": ">=20.19"
  },
  "scripts": {
    "build": "turbo run build --filter=./apps/*",
    "dev": "bash scripts/dev.sh",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "ds:build": "pnpm --filter @majistudio/ogcr-design-system build:lib",
    "ds:watch": "turbo watch build:lib --filter=@majistudio/ogcr-design-system",
    "ds:storybook": "pnpm --filter @majistudio/ogcr-design-system storybook",
    "ds:sync": "bash scripts/sync-design-system.sh"
  },
  "devDependencies": {
    "turbo": "^2"
  }
}
